# Локальный OpenAI-совместимый API (GET /v1/models, POST /v1/chat/completions и др.)
# Без Docker: укажите адрес LM Studio (например http://127.0.0.1:1234).
# В Docker: укажите http://host.docker.internal:1234 чтобы контейнер видел LM Studio на хосте.
API_BASE_URL=http://host.docker.internal:1234
API_KEY=dummy
MODEL_NAME=google/gemma-3n-e4b

# Провайдер LLM задаётся в веб-настройках (LM Studio / OpenRouter). Токен OpenRouter можно задать здесь или в настройках.
OPENROUTER_API_KEY=

INTRO_INTERVAL=300
MAX_TOKENS=1024
INTRO_MAX_TOKENS=512
# Размер контекста модели (токенов). При превышении старые мысли и диалог суммаризируются (LM Studio часто 4096).
CONTEXT_LIMIT=4096
DEBUG=True
DB_PATH=./data/db.sqlite
UPLOAD_FOLDER=./uploads
DEFAULT_INTRO_PROMPT=Ты — мыслящая система. Кратко поразмышляй о текущем состоянии знаний и приоритетах. Будь лаконичен.

# Режим размышлений модели (reasoning): отключение и лимит токенов на размышления — в веб-настройках.

# Опционально: Telegram-бот
# TELEGRAM_BOT_TOKEN=
